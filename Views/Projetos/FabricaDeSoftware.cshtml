@{
    ViewData["Title"] = "Portfólio";
    Layout = "_Layout";
}

@section Styles {
  <link rel="stylesheet" href="~/css/home.css">
  <link rel="stylesheet" href="~/css/Projetos.css">
  <link rel="stylesheet" href="~/css/Habilidades.css">
  <link rel="stylesheet" href="~/css/ProjetosCss/AurumLegacy.css">

  <link rel="stylesheet" href="hero.css">
}
<partial name="_BackButton" />
<section class="hero">
  
  <canvas id="particles-canvas"></canvas>
  <div class="hero-grid">

    <div class="hero-text">

      <h2>Fabrica De Software</h2>

    </div>

    <div class="hero-photo">
      Esse projeto foi desenvolvido em parceria com a empresa de tecnologia Tegra, promete auxiliar o estruturamento de projetos com IA.
    </div>

  </div>
</section>



<section id="projetos" class="section">
  <h3>Protótipos</h3>

  <div class="cards">
      <div class="card">
          <img src="~/img/FS1.png" alt="Aurum Legacy Screenshot 1" class="img1"/>
      </div>
      <div class="card">
          <img src="~/img/FS2.png" alt="Aurum Legacy Screenshot 1" class="img1"/>
      </div>
      <div class="card">
          <img src="~/img/FS3.png" alt="Aurum Legacy Screenshot 1" class="img1"/>
      </div>
      <div class="card">
          <img src="~/img/FS4.png" alt="Aurum Legacy Screenshot 1" class="img1"/>
      </div>
  </div>
</section>




